# ── WebSocket Server ──────────────────────────────────────────────────────────
PORT=8080

# ── Shared secret — must match JWT_SECRET in the NestJS .env ─────────────────
JWT_SECRET=tu_super_secreto_jwt_local

# ── NestJS REST API base URL ──────────────────────────────────────────────────
# Use the Docker service name when running inside docker-compose.
NESTJS_API_URL=http://api-nest:3000
# For local development outside Docker:
# NESTJS_API_URL=http://localhost:3000

# ── Game settings ─────────────────────────────────────────────────────────────
GAME_ROUNDS=5
ROUND_TIMEOUT_SECONDS=30
