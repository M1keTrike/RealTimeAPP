# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Credenciales del contenedor de base de datos.
# DB_USER y DB_PASSWORD en la API reutilizan estos mismos valores.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ─── JWT (compartido entre API y WebSocket) ────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── WebSocket — Configuración de partida ─────────────────────────────────────
GAME_ROUNDS=5
ROUND_TIMEOUT_SECONDS=30
